{
  "name": "@spomen/api",
  "version": "0.0.2",
  "description": "API for Spomen",
  "author": "anclaev <iahugo@yandex.ru>",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prisma:local": "dotenv -e .env.local yarn prisma",
    "build": "nest build && yarn sentry:sourcemaps",
    "build:production": "nest build && yarn sentry:sourcemaps:production",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:production": "node dist/main",
    "start:migrate:production": "prisma migrate deploy && node main",
    "dev": " cross-env NODE_ENV=local nest start --watch",
    "debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docs": "compodoc -c .compodocrc",
    "docs:serve": "compodoc -c .compodocrc -s",
    "prepare": "husky",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org anclaev-ti --project spomen-api ./dist/src && sentry-cli sourcemaps upload --org anclaev-ti --project spomen-api ./dist/src",
    "sentry:sourcemaps:production": "sentry-cli sourcemaps inject --org anclaev-ti --project spomen-api ./dist && sentry-cli sourcemaps upload --org anclaev-ti --project spomen-api ./dist"
  },
  "dependencies": {
    "@apollo/server": "^4.10.4",
    "@nestjs/apollo": "^12.1.0",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/graphql": "^12.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.12.1",
    "@sentry/cli": "^2.32.1",
    "@sentry/node": "^8.13.0",
    "@sentry/profiling-node": "^8.13.0",
    "@vkid/sdk": "^1.1.0",
    "argon2": "^0.40.1",
    "axios": "^1.7.2",
    "cache-manager": "^5.5.1",
    "class-serializer": "^0.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "cross-env": "^7.0.3",
    "generate-password-ts": "^1.6.5",
    "graphql": "^16.8.1",
    "graphql-parse-resolve-info": "^4.13.0",
    "graphql-type-json": "^0.3.2",
    "joi": "^17.12.3",
    "moment": "^2.30.1",
    "nest-winston": "^1.9.4",
    "nestjs-minio": "^2.6.1",
    "nestjs-object-id": "^1.2.1",
    "nestjs-prisma": "^0.23.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma-graphql-type-decimal": "^3.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.23",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.5.0",
    "jest-mock-extended": "^3.0.7",
    "lint-staged": "^15.2.2",
    "node-mocks-http": "^1.14.1",
    "prettier": "^3.2.5",
    "prisma": "^5.12.1",
    "prisma-nestjs-graphql": "^20.0.2",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "resolutions": {
    "wrap-ansi": "7.0.0",
    "string-width": "4.1.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "@interceptors/(.*)$": "<rootDir>/common/interceptors/$1",
      "@interfaces/(.*)$": "<rootDir>/common/interfaces/$1",
      "@decorators/(.*)$": "<rootDir>/common/decorators/$1",
      "@graphql/(.*)$": "<rootDir>/common/graphql/$1",
      "@enums/(.*)$": "<rootDir>/common/enums/$1",
      "@utils/(.*)$": "<rootDir>/common/utils/$1",
      "@mocks/(.*)$": "<rootDir>/common/mocks/$1",
      "@common/(.*)$": "<rootDir>/common/$1",
      "@core/(.*)$": "<rootDir>/core/$1",
      "@/(.*)$": "<rootDir>/$1"
    },
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.{!(module|guard),}.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": "25%"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ],
    "*.md": "prettier --write"
  }
}
