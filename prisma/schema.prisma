generator client {
    provider = "prisma-client-js"
}

generator graphql {
    provider                              = "prisma-nestjs-graphql"
    output                                = "../src/common/graphql"
    fields_Validator_from                 = "class-validator"
    fields_Validator_input                = true
    requireSingleFieldsInWhereUniqueInput = true
    emitSingle                            = true
    emitCompiled                          = true
    purgeOutput                           = true
    noTypeId                              = true
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Permission {
    Public
    Family
    Owner
}

enum Role {
    Public
    Verified
    Admin
}

model Account {
    id       String  @id @default(uuid())
    login    String  @unique
    email    String? @unique
    password String
    roles    Role[]

    avatar   Upload? @relation(name: "accountAvatar", fields: [avatarId], references: [id])
    avatarId String?

    vkId     String? @unique
    vkAvatar String?

    name     String?
    surname  String?
    birthday DateTime? @db.Date

    uploads Upload[] @relation("uploadOwner")
    chats   Chat[]   @relation("chatMembers")

    ownedMessages Message[]
    ownedReviews  Review[]
    ownedChats    Chat[]    @relation("chatOwner")
    ownedEvents   Event[]   @relation("eventOwner")

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Event {
    id          String       @id @default(uuid())
    name        String
    description String
    date        DateTime?    @db.Date
    permissions Permission[]

    pic   Upload @relation(name: "picUpload", fields: [picId], references: [id])
    picId String

    owner   Account @relation(name: "eventOwner", fields: [ownerId], references: [id])
    ownerId String

    reviews Review[]
    uploads Upload[] @relation("eventUploads")

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Review {
    id          String       @id @default(uuid())
    text        String
    permissions Permission[]

    author   Account @relation(fields: [authorId], references: [id])
    authorId String

    event   Event  @relation(fields: [eventId], references: [id])
    eventId String @unique

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Chat {
    id String @id @default(uuid())

    title String?

    owner   Account @relation(name: "chatOwner", fields: [ownerId], references: [id])
    ownerId String

    pic   Upload @relation(fields: [picId], references: [id])
    picId String

    messages Message[]
    members  Account[] @relation("chatMembers")

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Message {
    id   String @id @default(uuid())
    text String

    author   Account @relation(fields: [authorId], references: [id])
    authorId String

    chat   Chat   @relation(fields: [chatId], references: [id])
    chatId String

    uploads Upload[]

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Upload {
    id   String @id @default(uuid())
    name String
    ext  String
    url  String

    permissions Permission[]

    owner   Account @relation(name: "uploadOwner", fields: [ownerId], references: [id])
    ownerId String

    event   Event?  @relation(name: "eventUploads", fields: [eventId], references: [id])
    eventId String?

    accounts Account[] @relation("accountAvatar")
    events   Event[]   @relation("picUpload")
    chats    Chat[]
    messages Message[]

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}
