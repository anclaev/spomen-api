generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

enum Sex {
    Male
    Female
}

model Account {
    id       String  @id @default(auto()) @map("_id") @db.ObjectId
    login    String  @unique
    password String
    email    String? @unique

    vk_id  String? @unique
    vk_pic String?

    name     String?
    surname  String?
    sex      Sex?
    birthday DateTime? @db.Date

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
