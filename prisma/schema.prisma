generator client {
    provider = "prisma-client-js"
}

generator graphql {
    provider                              = "prisma-nestjs-graphql"
    output                                = "../src/common/graphql"
    fields_Validator_from                 = "class-validator"
    fields_Validator_input                = true
    requireSingleFieldsInWhereUniqueInput = true
    emitSingle                            = true
    emitCompiled                          = true
    purgeOutput                           = true
    noTypeId                              = true
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Gender {
    Male
    Female
}

enum Permission {
    Public
    Lovers
    Owner
}

enum Role {
    Public
    Lover
    Admin
}

model Account {
    id       String  @id @default(uuid())
    login    String  @unique
    email    String? @unique
    password String
    roles    Role[]

    avatar   Upload? @relation(name: "accountAvatar", fields: [avatarId], references: [id])
    avatarId String?

    vkId     String? @unique
    vkAvatar String?

    name     String?
    surname  String?
    gender   Gender?
    birthday DateTime? @db.Date

    uploads Upload[] @relation("uploadOwner")
    chats   Chat[]   @relation("chatMembers")

    offer Offer? @relation("offerTarget")

    love   Love?   @relation(name: "accountLove", fields: [loveId], references: [id])
    loveId String?

    ownedMessages Message[]
    ownedReviews  Review[]
    ownedLoves    Love[]    @relation("loveOwner")
    ownedOffers   Offer[]   @relation("offerOwner")
    ownedChats    Chat[]    @relation("chatOwner")

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Love {
    id    String @id @default(uuid())
    alias String @unique
    name  String

    isPrivate Boolean @default(false)

    partners Account[] @relation("accountLove")

    owner   Account @relation(name: "loveOwner", fields: [ownerId], references: [id])
    ownerId String

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
    Offer     Offer[]
}

model Event {
    id          String    @id @default(uuid())
    name        String
    description String
    date        DateTime? @db.Date

    pic   Upload @relation(name: "picUpload", fields: [picId], references: [id])
    picId String

    reviews Review[]
    uploads Upload[] @relation("eventUploads")

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Review {
    id          String       @id @default(uuid())
    text        String
    permissions Permission[]

    author   Account @relation(fields: [authorId], references: [id])
    authorId String

    event   Event  @relation(fields: [eventId], references: [id])
    eventId String @unique

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Offer {
    id   String @id @default(uuid())
    code String

    love   Love   @relation(fields: [loveId], references: [id])
    loveId String

    owner   Account @relation(name: "offerOwner", fields: [ownerId], references: [id])
    ownerId String

    target   Account @relation(name: "offerTarget", fields: [targetId], references: [id])
    targetId String  @unique

    isUsed Boolean @default(false)

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Chat {
    id String @id @default(uuid())

    title String?

    owner   Account @relation(name: "chatOwner", fields: [ownerId], references: [id])
    ownerId String

    pic   Upload @relation(fields: [picId], references: [id])
    picId String

    messages Message[]
    members  Account[] @relation("chatMembers")

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Message {
    id   String @id @default(uuid())
    text String

    author   Account @relation(fields: [authorId], references: [id])
    authorId String

    chat   Chat   @relation(fields: [chatId], references: [id])
    chatId String

    uploads Upload[]

    createdAt DateTime @default(now()) @db.Date
    updatedAt DateTime @updatedAt @db.Date
}

model Upload {
    id   String @id @default(uuid())
    name String
    ext  String
    url  String

    permissions Permission[]

    owner   Account @relation(name: "uploadOwner", fields: [ownerId], references: [id])
    ownerId String

    event   Event?  @relation(name: "eventUploads", fields: [eventId], references: [id])
    eventId String?

    events   Event[]   @relation("picUpload")
    accounts Account[] @relation("accountAvatar")
    chats    Chat[]
    messages Message[]

    createdAt DateTime @default(now()) @db.Date
}
